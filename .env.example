# ── Local providers ────────────────────────────────────────────────────────────
# Ollama (always available if running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_0
OLLAMA_MODEL_OPTIONS=llama3.1:8b-instruct-q4_0,gemma4:latest,mistral:latest

# LM Studio — leave LMSTUDIO_BASE_URL empty to disable
LMSTUDIO_BASE_URL=
LMSTUDIO_MODEL_OPTIONS=

# ── Cloud providers ────────────────────────────────────────────────────────────
# Add API key(s) for the providers you want. Leave blank to disable that provider.

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_OPTIONS=gemini-2.5-flash,gemini-2.5-pro

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_OPTIONS=gpt-4o-mini,gpt-4o,o3-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_OPTIONS=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-7

# ── Routing ────────────────────────────────────────────────────────────────────
MAX_PROMPT_CHARS=8000

# ── Storage ────────────────────────────────────────────────────────────────────
LOG_FILE=logs/router.log
MEMORY_DB_PATH=data/memory.db
